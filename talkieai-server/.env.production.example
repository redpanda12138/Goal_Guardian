AI_NAME=Talkie

# Required Neon PostgreSQL connection.
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST/neondb?sslmode=require

# Optional Azure Speech configuration.
AZURE_KEY=

# Supported values: CHAT_GPT or ZHIPU.
AI_SERVER=ZHIPU

# Main backend OpenAI-compatible configuration.
CHAT_GPT_PROXY=
CHAT_GPT_KEY=
CHAT_GPT_MODEL=gpt-4.1

# MAS OpenAI-compatible configuration.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# Rotate any key that has appeared in Git history before production use.
ZHIPU_AI_API_KEY=replace-with-rotated-production-key
ZHIPU_AI_MODEL=glm-4.7

# Container file paths and host-side model mount.
TEMP_SAVE_FILE_PATH=/app/files
WHISPER_MODEL_HOST_PATH=./talkieai-server/mas/whisper-medium-sing2eng-translate
WHISPER_MODEL_PATH=/models/whisper
WHISPER_MODEL_PROFILE=medium
WHISPER_NOISEREDUCE=0

# Required only when building with docker-compose.gpu.yml.
PYTORCH_GPU_INDEX_URL=https://download.pytorch.org/whl/REPLACE_WITH_CUDA_INDEX
PYTORCH_GPU_VERSION=2.11.0

# Backend API and token settings.
API_PREFIX=/api
TOKEN_SECRET=replace-with-random-256-bit-secret
TOKEN_EXPIRE_TIME=43200
SQL_ECHO=False

# Docker-internal MAS endpoints.
MAS_MMA_URL=http://mma:8000
MAS_SOA_URL=http://soa:8000
MAS_GRA_URL=http://gra:8000
MAS_SCA_URL=http://sca:8000
MAS_SSA_URL=http://ssa:8000
MAS_OA_URL=http://oa:8000
MAS_HTTP_CONNECT_TIMEOUT=10
MAS_HTTP_READ_TIMEOUT=120
MAS_OA_SCHEDULER_ENABLED=true
MAS_MEMORY_REQUIRE_DATABASE=true
OA_SCHEDULE_TZ=Asia/Shanghai

# Optional WeChat integration.
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WE_CHAT_SERVER_URL=
