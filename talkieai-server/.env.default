AI_NAME=Talkie

# Required database connection. Use Neon/Postgres for the current project.
DATABASE_URL='postgresql+psycopg2://{username}:{password}@{host}/{database}?sslmode=require'

# Optional Azure Speech key.
AZURE_KEY=

# Supported values: CHAT_GPT or ZHIPU.
AI_SERVER=ZHIPU

# Main backend OpenAI-compatible configuration.
CHAT_GPT_PROXY=
CHAT_GPT_KEY=
CHAT_GPT_MODEL=gpt-4.1

# MAS OpenAI-compatible configuration.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# ZhipuAI configuration shared by the backend and MAS services.
ZHIPU_AI_API_KEY=
ZHIPU_AI_MODEL=glm-4.7

# Local file and Whisper model settings.
TEMP_SAVE_FILE_PATH=./files
WHISPER_MODEL_PROFILE=medium
# WHISPER_MODEL_PATH=mas/whisper-medium-sing2eng-translate

# Backend API and token settings.
API_PREFIX=/api
TOKEN_SECRET=replace-with-a-random-secret
SQL_ECHO=False
TOKEN_EXPIRE_TIME=43200

# Local backend -> Docker-published MAS service URLs.
MAS_MMA_URL=http://localhost:8001
MAS_SOA_URL=http://localhost:8002
MAS_GRA_URL=http://localhost:8003
MAS_SCA_URL=http://localhost:8004
MAS_SSA_URL=http://localhost:8005
MAS_OA_URL=http://localhost:8006
MAS_HTTP_CONNECT_TIMEOUT=10
MAS_HTTP_READ_TIMEOUT=120
MAS_OA_SCHEDULER_ENABLED=true
OA_SCHEDULE_TZ=Asia/Shanghai
